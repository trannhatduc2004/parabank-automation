{
  "name": "parabank-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "allure:serve": "allure serve allure-results",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "report": "playwright show-report reports/html",
    "perf:load":   "k6 run src/performance/load-test.js",
    "perf:stress": "k6 run src/performance/stress-test.js",
    "perf:spike":  "k6 run src/performance/spike-test.js",
    "perf:all":    "k6 run src/performance/load-test.js && k6 run src/performance/stress-test.js",
    "test:security": "playwright test --project=chromium src/e2e/tests/security.spec.ts"

      },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "allure-playwright": "^3.7.2",
    "dotenv": "^17.4.2",
    "wait-on": "^9.0.8",
    "zod": "^4.4.3"
  }
}
